# === Required ===
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/verin?sslmode=require
REDIS_URL=rediss://default:password@your-upstash-host.upstash.io:6379
SESSION_SECRET=generate-a-random-64-char-string
DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111

# === Cloudflare R2 Storage ===
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_BUCKET=verin-documents
S3_REGION=auto
S3_USE_PATH_STYLE=true

# === App ===
APP_ENV=production
APP_PORT=8080
WEB_ORIGIN=https://your-app.vercel.app

# === Optional ===
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_FROM=noreply@yourdomain.com
# MFA_ENCRYPTION_KEY=32-byte-hex-key
