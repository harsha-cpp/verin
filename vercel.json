{
  "buildCommand": "pnpm --filter @verin/web... build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/healthz", "destination": "https://verin-api.onrender.com/healthz" },
    { "source": "/api/(.*)", "destination": "https://verin-api.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
